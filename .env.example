# Formspree form endpoint IDs
# Copy this file to .env.local and replace with your actual Formspree form IDs
# Get your form IDs at https://formspree.io
NEXT_PUBLIC_FORMSPREE_WAITLIST=your_form_id_here
NEXT_PUBLIC_FORMSPREE_INQUIRY=your_form_id_here
NEXT_PUBLIC_FORMSPREE_MAINTENANCE=your_form_id_here
NEXT_PUBLIC_FORMSPREE_BUYER=your_form_id_here
NEXT_PUBLIC_FORMSPREE_CONTACT=your_form_id_here
